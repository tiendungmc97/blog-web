#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🔍 Validating commit message...${NC}"

# Run commitlint
npx --no -- commitlint --edit $1

if [ $? -ne 0 ]; then
    echo ""
    echo -e "${RED}❌ Commit message validation failed!${NC}"
    echo ""
    echo -e "${YELLOW}📋 Conventional Commit Format:${NC}"
    echo -e "${BLUE}   <type>[optional scope]: <description>${NC}"
    echo ""
    echo -e "${YELLOW}📝 Valid types (synced with git-workflow-guidelines.md):${NC}"
    echo -e "${GREEN}   feat${NC}     - ✨ New feature"
    echo -e "${GREEN}   fix${NC}      - 🐛 Bug fix"
    echo -e "${GREEN}   refactor${NC} - ♻️ Code improvement"
    echo -e "${GREEN}   docs${NC}     - 📚 Documentation"
    echo -e "${GREEN}   style${NC}    - 💄 Formatting, UI"
    echo -e "${GREEN}   test${NC}     - ✅ Testing"
    echo -e "${GREEN}   chore${NC}    - 🔧 Build/config"
    echo -e "${GREEN}   perf${NC}     - ⚡ Performance"
    echo ""
    echo -e "${YELLOW}💡 Examples (from git-workflow-guidelines.md):${NC}"
    echo -e "${BLUE}   feat(auth): add Google OAuth integration${NC}"
    echo -e "${BLUE}   fix(ui): prevent form flicker on page load${NC}"
    echo -e "${BLUE}   refactor(utils): simplify date formatter logic${NC}"
    echo -e "${BLUE}   docs(readme): update installation guide${NC}"
    echo -e "${BLUE}   style(button): update primary button colors${NC}"
    echo -e "${BLUE}   test(auth): add unit tests for login flow${NC}"
    echo -e "${BLUE}   chore(deps): update React to v18.2.0${NC}"
    echo -e "${BLUE}   perf(api): optimize database queries${NC}"
    echo ""
    echo -e "${YELLOW}🚀 Quick fix: Use interactive mode:${NC}"
    echo -e "${BLUE}   npm run commit${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ Commit message is valid!${NC}"